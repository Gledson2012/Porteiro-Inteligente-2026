<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".PorteiroInteligenteApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PorteiroInteligente"
        tools:targetApi="31">

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title" />

        <activity
            android:name=".ui.visit.VisitHistoryActivity"
            android:exported="false"
            android:label="@string/visits_history_title" />

        <activity
            android:name=".ui.visit.VisitRegistrationActivity"
            android:exported="false"
            android:label="@string/visit_reg_title"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.scanner.ScannerActivity"
            android:exported="false"
            android:label="@string/scanner_title"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.owner.OwnerDetailsActivity"
            android:exported="false"
            android:label="@string/owner_details_title" />

        <activity
            android:name=".ui.owner.OwnerRegistrationActivity"
            android:exported="false"
            android:label="@string/owner_reg_title"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.PorteiroInteligente">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false"
            android:label="@string/app_name" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
